# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# development | production — set production on live deploy; use development on staging to block indexing
NEXT_PUBLIC_SITE_ENV=development

# Sanity CMS — https://www.sanity.io/manage
# Use current date (YYYY-MM-DD) to target the latest API version
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-18
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_READ_TOKEN=

# AI demo (optional — samples work without these)
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
AI_DEMO_PROVIDER=openai
AI_DEMO_MODEL=gpt-4o-mini
AI_DEMO_MAX_TOKENS=1200
AI_DEMO_TEMPERATURE=0.7
AI_DEMO_TIMEOUT_MS=15000

# Bot protection for live AI in production (optional locally)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
